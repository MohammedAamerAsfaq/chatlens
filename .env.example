# ChatLens Environment Configuration
# Copy this file to .env.local_dev and fill in your values.
# Do NOT commit real env files to git.

# --- Django ---
SECRET_KEY=change-me-generate-with-python-manage-generate-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (PostgreSQL) ---
DB_NAME=chatlens
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_HOST=localhost
DB_PORT=5432

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379

# --- Celery ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# --- Cache ---
CACHE_ENABLED=false
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=chatlens:dev

# --- Internal API Token (shared with Node.js WhatsApp worker) ---
INTERNAL_API_TOKEN=change-me-internal-token
